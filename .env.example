# vLLM runtime
VLLM_IMAGE=vllm/vllm-openai:latest
MODEL_ID=mistralai/Ministral-3-8B-Instruct-2512
SERVED_MODEL_NAME=ministral-8b
VLLM_PORT=8000
VLLM_BIND_IP=0.0.0.0
# Comma-separated list of CIDRs allowed to reach VLLM_PORT on the host firewall.
# Example: VLLM_ALLOWED_CIDRS=51.15.10.20/32,10.0.0.0/8
VLLM_ALLOWED_CIDRS=
# Optional: auto-resolve one instance IP and add it as /32 to VLLM_ALLOWED_CIDRS.
# If SCW_PRIVATE_NETWORK_NAME is set, scripts prefer the source instance private IPv4 on that network.
# Otherwise they fall back to its public IP.
# Example: VLLM_ALLOWED_CIDRS_FROM_SERVER_NAME=schligler-ia-parser
VLLM_ALLOWED_CIDRS_FROM_SERVER_NAME=
VLLM_DTYPE=float16
GPU_MEMORY_UTILIZATION=0.90
MAX_MODEL_LEN=8192
MAX_NUM_SEQS=24
# Max seconds deploy/redeploy waits for vLLM API readiness (/v1/models).
VLLM_READY_TIMEOUT_SEC=900
HF_CACHE_DIR=/data/models

# Optional: required if model access is gated on Hugging Face
HUGGING_FACE_HUB_TOKEN=

# Scaleway deploy values
SCW_ZONE=fr-par-2
SCW_COMMERCIAL_TYPE=L4-1-24G
SCW_IMAGE=
SCW_IMAGE_FALLBACK=ubuntu_jammy
SCW_SERVER_NAME=llm-ministral-vllm
SCW_VOLUME_SIZE_GB=80
SCW_ROOT_VOLUME=sbs:80GB
# Public IP mode passed to `scw instance server create ip=...`.
# Use `dynamic` to avoid billable flexible IP allocation (recommended).
# Use `none` only if you have private-network access to the server.
SCW_SERVER_IP=dynamic
# When true, deploy uses the public IP for bootstrap then detaches it at the end.
SCW_DETACH_PUBLIC_IP_AFTER_DEPLOY=false
# Required when SCW_SERVER_IP=none. Existing private network name to attach.
SCW_PRIVATE_NETWORK_NAME=
# Optional explicit region for private-network lookup (defaults to SCW_ZONE without the last segment, e.g. fr-par).
SCW_REGION=
SCW_SSH_USER=ubuntu
SCW_SSH_PUBLIC_KEY_PATH=$HOME/.ssh/scaleway.pub
SCW_SSH_PRIVATE_KEY_PATH=
